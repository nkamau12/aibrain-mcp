# aiBrain MCP — Environment Variables

# Directory where memories are stored (default: ~/.aibrain/memories)
# AIBRAIN_DATA_DIR=/path/to/custom/dir

# Ollama settings (for semantic/vector search)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=nomic-embed-text
# OLLAMA_TIMEOUT_MS=5000

# Logging level: debug | info | warn | error
# LOG_LEVEL=info
