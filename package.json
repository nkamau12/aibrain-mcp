    "@modelcontextprotocol/sdk": "^1.0.0",
    "apache-arrow": "^18.0.0",
    "dotenv": "^16.0.0",
    "uuid": "^11.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.6.0"
  }
